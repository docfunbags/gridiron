/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; img-src 'self' https://cdn.sanity.io data:; script-src 'self' 'unsafe-inline' https://w.behold.so https://embedsocial.com; frame-src https://maps.google.com https://www.google.com https://embedsocial.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://*.api.sanity.io https://*.apicdn.sanity.io https://w.behold.so; object-src 'none'; base-uri 'self'

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
