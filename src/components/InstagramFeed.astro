<section class="band-dark">
  <div class="section">
    <div class="instagram-grid">
      <div>
        <span class="kicker reveal">Meanwhile, On the Socials</span>
        <h2 class="ig-h reveal d1">You Had to<br />Be There.</h2>
        <p class="body-on-cream-dim reveal d1">Follow along for live music nights, tap releases, and whatever else is happening on the patio.</p>
        <a href="https://www.instagram.com/gridironbrewing/" target="_blank" rel="noopener" class="btn btn-ghost reveal d2">
          @gridironbrewing →
        </a>
      </div>

      <div class="reveal d1 ig-embed" id="ig-embed-host" data-feed="ZuG5brrsTYIf9rA9yY1v"></div>
    </div>
  </div>
</section>

<script>
  // Lazy-load the Behold Instagram widget only when the section scrolls into view
  const host = document.getElementById('ig-embed-host');
  if (host) {
    const load = () => {
      const feedId = host.dataset.feed;
      if (!feedId) return;
      const widget = document.createElement('behold-widget');
      widget.setAttribute('feed-id', feedId);
      host.appendChild(widget);
      const s = document.createElement('script');
      s.type = 'module';
      s.src = 'https://w.behold.so/widget.js';
      document.head.appendChild(s);
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            load();
            io.disconnect();
          }
        });
      }, { rootMargin: '200px' });
      io.observe(host);
    } else {
      load();
    }
  }
</script>
