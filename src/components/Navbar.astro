---
const navLinks = [
  { label: 'Beers', href: '#beers' },
  { label: 'Taproom', href: '#taproom' },
  { label: 'Events', href: '#events' },
  { label: 'About', href: '#about' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-md border-b border-white/10">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-amber-400 text-2xl">⬡</span>
      <span class="text-white font-black text-xl tracking-widest uppercase">Gridiron</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="text-zinc-400 hover:text-white text-sm font-medium tracking-widest uppercase transition-colors duration-200"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#taproom"
      class="hidden md:inline-flex items-center gap-2 bg-amber-400 hover:bg-amber-300 text-black text-sm font-bold tracking-widest uppercase px-5 py-2.5 transition-colors duration-200"
    >
      Visit Us
    </a>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden text-white p-2"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-black border-t border-white/10">
    <ul class="flex flex-col px-6 py-4 gap-4">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="block text-zinc-400 hover:text-white text-sm font-medium tracking-widest uppercase transition-colors duration-200"
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="#taproom"
          class="inline-flex bg-amber-400 hover:bg-amber-300 text-black text-sm font-bold tracking-widest uppercase px-5 py-2.5 transition-colors duration-200"
        >
          Visit Us
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
