---
import Lightbox from './Lightbox.astro';
import { photos } from '../data/community';

// Cap the client-side pool to keep the data attribute reasonable as content grows
const pool = photos.slice(0, 60);
const initial = pool.slice(0, 6);
---

<section class="band-amber">
  <div class="section">
    <div class="community-outer">
      <div>
        <span class="kicker kicker-amber-deep reveal">In The Community</span>
        <h2 class="community-h reveal d1">
          Drink Local.<br />Support Local.<br /><span>Drink Gridiron.</span>
        </h2>
        <p class="body-on-amber reveal d1">Whether you're tapping your toes to live music, racking your brain at trivia night, or just dropping by for a quiet Thursday pint, you've made this more than a place to grab a drink. You've made it a place to belong.</p>
        <p class="body-on-amber reveal d2">Dogs, kids, and good folks are always welcome.</p>
        <div class="stack-buttons-sm reveal d3">
          <a class="btn btn-ink-deep" href="/gallery">See the memories we're making →</a>
        </div>
      </div>

      <div class="community-mosaic reveal d1" id="community-mosaic" data-pool={JSON.stringify(pool)}>
        {initial.map(p => (
          <div class="mosaic-item lb-trigger" role="button" tabindex="0" data-src={p.srcFull} data-alt={p.alt}>
            <img src={p.src} alt={p.alt} loading="lazy" decoding="async" />
          </div>
        ))}
      </div>

      <Lightbox id="community-lightbox" />
    </div>
  </div>
</section>

<style>
  .community-mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 1fr;
    gap: 20px;
    overflow: visible;
    padding: 12px;
  }
  .community-mosaic::before {
    content: '';
    width: 0;
    padding-bottom: 100%;
    grid-row: 1;
    grid-column: 1;
  }
  .community-mosaic > *:first-child {
    grid-row: 1;
    grid-column: 1;
  }

  .mosaic-item {
    aspect-ratio: 1;
    position: relative;
    z-index: 1;
    cursor: zoom-in;
    background: #fff;
    padding: 7px 7px 24px;
    box-shadow: 2px 3px 10px rgba(0,0,0,0.18), 0 1px 3px rgba(0,0,0,0.10);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .mosaic-item:nth-child(1) { transform: rotate(-1.5deg); }
  .mosaic-item:nth-child(2) { transform: rotate( 1.2deg); }
  .mosaic-item:nth-child(3) { transform: rotate(-0.6deg); }
  .mosaic-item:nth-child(4) { transform: rotate( 2.0deg); }
  .mosaic-item:nth-child(5) { transform: rotate(-1.8deg); }
  .mosaic-item:nth-child(6) { transform: rotate( 0.8deg); }

  .mosaic-item:hover {
    transform: rotate(0deg) scale(1.08) !important;
    z-index: 10;
    box-shadow: 6px 14px 32px rgba(0,0,0,0.28);
  }

  .mosaic-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 1;
    transition: opacity 0.6s ease;
  }

  .mosaic-item img.fading {
    opacity: 0;
  }
</style>

<script>
  import { bindLightbox } from '../utils/lightbox';

  const mosaic = document.getElementById('community-mosaic') as HTMLElement | null;
  const lb = document.getElementById('community-lightbox');
  if (!mosaic || !lb) {
    // nothing to do
  } else {
    bindLightbox('community-lightbox', '#community-mosaic .mosaic-item');

    const pool: { src: string; srcFull: string; alt: string }[] = JSON.parse(mosaic.dataset.pool || '[]');
    let hovering = false;
    const paused = () => hovering || lb.classList.contains('open');

    mosaic.addEventListener('mouseenter', () => { hovering = true; });
    mosaic.addEventListener('mouseleave', () => { hovering = false; });

    if (pool.length > 6) {
      const items = Array.from(mosaic.querySelectorAll('.mosaic-item')) as HTMLElement[];
      let slotIdx = 0;
      let queue: typeof pool = [];

      setInterval(() => {
        if (paused()) return;

        const slot = items[slotIdx % items.length];
        slotIdx++;

        const shown = new Set(items.map(el => el.getAttribute('data-src')));

        if (queue.filter(p => !shown.has(p.srcFull)).length === 0) {
          queue = pool.filter(p => !shown.has(p.srcFull));
        }

        const eligible = queue.filter(p => !shown.has(p.srcFull));
        if (eligible.length === 0) return;

        const next = eligible[Math.floor(Math.random() * eligible.length)];
        queue = queue.filter(p => p.srcFull !== next.srcFull);

        const img = slot.querySelector('img') as HTMLImageElement | null;
        if (!img) return;

        img.classList.add('fading');
        setTimeout(() => {
          img.src = next.src;
          img.alt = next.alt;
          slot.setAttribute('data-src', next.srcFull);
          slot.setAttribute('data-alt', next.alt);
          requestAnimationFrame(() => requestAnimationFrame(() => img.classList.remove('fading')));
        }, 600);
      }, 4500);
    }
  }
</script>
