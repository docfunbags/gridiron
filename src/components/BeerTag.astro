---
import type { Beer } from '../data/beers';
interface Props { tag: Beer['tag']; }
const { tag } = Astro.props;
const labelMap = { flagship: 'Flagship', seasonal: 'Seasonal', guest: 'Guest', hidden: '' } as const;
const clsMap   = { flagship: '',         seasonal: ' seasonal', guest: ' guest', hidden: ''  } as const;
---
{tag !== 'hidden' && <span class={`tag${clsMap[tag]}`}>{labelMap[tag]}</span>}
