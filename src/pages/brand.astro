---
import Layout from '../layouts/Layout.astro';
import { activeSchedule } from '../data/settings';

const description = 'Gridiron Brewing design system — color, typography, and visual assets.';
---

<Layout title="Brand — Gridiron Brewing" description={description} activeNav="Brand" hours={activeSchedule}>
  <section class="page-hero grain">
    <span class="kicker">Brand System</span>
    <h1>Design Reference</h1>
    <p>Color, typography, buttons, and components — the full visual language for Gridiron Brewing.</p>
  </section>

  <!-- 01 Color -->
  <section class="section" id="color">
    <div class="section-head">
      <span class="kicker">01 — Color</span>
      <h2>Palette</h2>
      <p class="lead">The color system relies on high-contrast pairings, mixing warm "paper" tones with deep "inks" and "ambers".</p>
    </div>

    <h3 class="subsection-title label">Primary UI Colors</h3>
    <div class="swatch-grid">
      <div class="swatch">
        <div class="swatch-color" style="background: var(--paper);"></div>
        <div class="swatch-meta">
          <p class="name">Paper</p>
          <p class="hex">#f1e6d0</p>
          <p class="token label">--paper</p>
        </div>
      </div>
      <div class="swatch">
        <div class="swatch-color" style="background: var(--cream);"></div>
        <div class="swatch-meta">
          <p class="name">Cream</p>
          <p class="hex">var(--cream)</p>
          <p class="token label">--cream</p>
        </div>
      </div>
      <div class="swatch">
        <div class="swatch-color" style="background: var(--ink); color: var(--cream);"></div>
        <div class="swatch-meta">
          <p class="name">Ink</p>
          <p class="hex">#211711</p>
          <p class="token label">--ink</p>
        </div>
      </div>
      <div class="swatch">
        <div class="swatch-color" style="background: var(--amber);"></div>
        <div class="swatch-meta">
          <p class="name">Amber</p>
          <p class="hex">#c17a2b</p>
          <p class="token label">--amber</p>
        </div>
      </div>
    </div>

    <h3 class="subsection-title label" style="margin-top: 48px;">Extended UI Colors</h3>
    <div class="swatch-grid extended">
      <div class="swatch"><div class="swatch-color" style="background: var(--paper-2);"></div><div class="swatch-meta"><p class="name">Paper 2</p><p class="hex">#e7d8ba</p><p class="token label">--paper-2</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--ink-2); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Ink 2</p><p class="hex">#3a2b1e</p><p class="token label">--ink-2</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--ink-3); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Ink 3</p><p class="hex">#5a4733</p><p class="token label">--ink-3</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--ink-deep); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Ink Deep</p><p class="hex">#1c130c</p><p class="token label">--ink-deep</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--amber-bright);"></div><div class="swatch-meta"><p class="name">Amber Bright</p><p class="hex">#e0962f</p><p class="token label">--amber-bright</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--amber-deep); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Amber Deep</p><p class="hex">#5a2c14</p><p class="token label">--amber-deep</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--rust); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Rust</p><p class="hex">#8b3a2b</p><p class="token label">--rust</p></div></div>
      <div class="swatch"><div class="swatch-color" style="background: var(--red); color: var(--cream);"></div><div class="swatch-meta"><p class="name">Red</p><p class="hex">#d83a29</p><p class="token label">--red</p></div></div>
    </div>
  </section>

  <!-- 02 Typography -->
  <section class="band-paper2" id="typography">
    <div class="section">
      <div class="section-head">
        <span class="kicker">02 — Typography</span>
        <h2>Type Scale</h2>
        <p class="lead">Industrial, hand-lettered feel using Anton for display, Archivo for body, and DM Mono for kickers and labels.</p>
      </div>

      <div class="type-stack">
        <div class="type-row">
          <div class="meta"><span class="label">Hero H1</span><p>Anton 400 · fluid</p></div>
          <div class="sample"><h1 class="display-ink" style="margin:0;">Cold Pints.</h1></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Section H2</span><p>Anton 400 · fluid</p></div>
          <div class="sample"><h2 class="display-ink-md" style="margin:0;">When We're Pouring</h2></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Card H3</span><p>Anton 400 · 26px</p></div>
          <div class="sample"><h3 style="font-family: 'Anton', sans-serif; font-weight: 400; font-size: 26px; text-transform: uppercase; line-height: .92; color: var(--ink);">House White</h3></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Subheading H4</span><p>Archivo 700 · 22px</p></div>
          <div class="sample"><h4>Music on the Deck</h4></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Lead Body</span><p>Archivo 400 · 17px/18px</p></div>
          <div class="sample"><p class="lead" style="margin:0;">Twenty-five minutes from uptown Saint John, right where Main Street bends to meet the water.</p></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Base Body</span><p>Archivo 400 · 16px</p></div>
          <div class="sample"><p style="margin:0;">Our on-site spots fill up fast, so getting here early is your best bet.</p></div>
        </div>
        <div class="type-row">
          <div class="meta"><span class="label">Kicker / Label</span><p>DM Mono 400/500</p></div>
          <div class="sample"><span class="kicker">Opening Hours</span><br/><br/><span class="label">Parking</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 Components -->
  <section class="section" id="components">
    <div class="section-head">
      <span class="kicker">03 — Components</span>
      <h2>Buttons & Interactions</h2>
      <p class="lead">A unified button system using a 6px border radius and a distinct translation/shadow lift on hover.</p>
    </div>

    <div class="comp-grid">
      <div class="comp-box light">
        <h4 class="label">Standard Buttons</h4>
        <div class="stack-buttons">
          <a class="btn btn-amber" href="#">Primary Amber</a>
          <a class="btn btn-ink" href="#">Solid Ink</a>
          <a class="btn btn-ink-deep" href="#">Ink Deep</a>
          <a class="btn btn-ghost" style="color:var(--ink);" href="#">Ghost Dark</a>
        </div>
      </div>
      <div class="comp-box dark">
        <h4 class="label">Dark Band Buttons</h4>
        <div class="stack-buttons">
          <a class="btn btn-amber" href="#">Primary Amber</a>
          <a class="btn btn-ghost-cream" href="#">Ghost Cream</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .subsection-title { margin-bottom: 24px; color: var(--ink-2); }
  
  .swatch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .swatch-grid.extended { grid-template-columns: repeat(4, 1fr); }
  .swatch { border-radius: 8px; overflow: hidden; border: 1px solid var(--line); background: var(--cream); }
  .swatch-color { height: 120px; border-bottom: 1px solid var(--line); }
  .swatch-meta { padding: 16px; }
  .swatch-meta .name { font-weight: 700; font-size: 15px; margin-bottom: 2px; color: var(--ink); }
  .swatch-meta .hex { font-family: 'DM Mono', monospace; font-size: 13px; color: var(--ink-2); margin-bottom: 12px; }
  .swatch-meta .token { margin-bottom: 0; color: var(--amber); text-transform: lowercase; }

  .type-stack { display: flex; flex-direction: column; border-top: 1px solid var(--line); }
  .type-row { display: grid; grid-template-columns: 240px 1fr; gap: 32px; padding: 32px 0; border-bottom: 1px solid var(--line); align-items: center; }
  .type-row .meta p { font-size: 14px; color: var(--ink-3); margin-top: 6px; }

  .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .comp-box { padding: 48px 32px; border-radius: 8px; border: 1px solid var(--line); }
  .comp-box.light { background: var(--cream); }
  .comp-box.dark { background: var(--ink); color: var(--cream); }
  .comp-box.dark .label { color: var(--amber-bright); }

  @media (max-width: 820px) {
    .swatch-grid, .swatch-grid.extended { grid-template-columns: repeat(2, 1fr); }
    .type-row { grid-template-columns: 1fr; gap: 16px; }
    .comp-grid { grid-template-columns: 1fr; }
  }
</style>