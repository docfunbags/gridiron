---
import Layout from '../layouts/Layout.astro';
import Lightbox from '../components/Lightbox.astro';
import { photos } from '../data/community';

const description = 'Community photos from the Gridiron Brewing taproom in Hampton, NB — shared by the people who make this place what it is.';
---

<Layout title="Community Gallery — Gridiron Brewing" description={description} activeNav="">
  <section class="page-hero grain">
    <span class="kicker">Our Community · Hampton, NB</span>
    <h1>The Gallery</h1>
    <p>Real moments from the taproom — shared by the people who make this place what it is.</p>
  </section>

  <section class="section">
    <div class="gallery-grid">
      {photos.map((photo) => (
        <div class="gallery-item lb-trigger" role="button" tabindex="0" data-src={photo.srcFull} data-alt={photo.alt}>
          <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </section>

  <section class="band-dark">
    <div class="section section-cta-tight">
      <span class="kicker kicker-amber-bright">Get Featured</span>
      <h2 class="display-cream-md">Tag Us<br />@gridironbrewing</h2>
      <p class="cta-lead">We go through every single one, argue about our favourites over a cold pint, and the best ones end up right here. Dogs jump the queue. You've been warned.</p>
      <a class="btn btn-amber" href="https://www.instagram.com/gridironbrewing/" target="_blank" rel="noopener">Follow on Instagram →</a>
    </div>
  </section>

  <Lightbox id="gallery-lightbox" withNav />
</Layout>

<script>
  import { bindLightbox } from '../utils/lightbox';
  bindLightbox('gallery-lightbox', '.gallery-item.lb-trigger', { withNav: true });
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .gallery-item {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 6px;
    cursor: zoom-in;
    border: 1px solid var(--line);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s var(--ease), filter 0.35s var(--ease);
  }

  .gallery-item:hover img {
    transform: scale(1.06);
    filter: brightness(1.08);
  }

  @media (max-width: 820px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 520px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>
